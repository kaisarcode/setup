#!/bin/bash
# aid - Run Aider in Podman against a remote Ollama server
# Summary: Runs Aider as a disposable container with local persistence.
# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

set -e

# Print command usage.
# @return 0 on success.
aid_help() {
    echo "Usage: aid <command> [args]"
    echo
    echo "Commands:"
    echo "  install   Install the Aider image"
    echo "  run       Run Aider in the current directory"
    echo "  status    Show local image status"
    echo "  remove    Remove local persistent data"
    echo "  nuke      Remove local persistent data and local image"
    echo
    echo "Environment:"
    echo "  OLLAMA_URL    Ollama server URL"
    echo "  AIDER_MODEL   Model name for Aider"
}

# Print one error message.
# @param $1 Error message.
# @return 1 on failure.
aid_fail() {
    echo "Error: $1" >&2
    return 1
}

# Run podman with rootless preference.
# @param $@ Podman arguments.
# @return 0 on success.
aid_podman() {
    local err_log
    local subcmd

    if [ "$(id -u)" -ne 0 ] && command -v podman >/dev/null 2>&1; then
        err_log=$(mktemp)
        if podman "$@" 2>"$err_log"; then
            rm -f "$err_log"
            return 0
        fi
        if ! grep -qE "Permission denied|cannot clone|OCI permission denied|gid_map" "$err_log"; then
            cat "$err_log" >&2
        fi
        rm -f "$err_log"
    fi

    if [ -d /dev/incus ] || [ -d /dev/lxd ]; then
        subcmd="$1"
        shift
        if [ "$subcmd" = "run" ]; then
            sudo podman run --userns=host --user "$(id -u):$(id -g)" "$@"
        else
            sudo podman "$subcmd" "$@"
        fi
        return
    fi

    sudo podman "$@"
}

# Resolve the Ollama base URL.
# @return URL on stdout.
resolve_ollama_url() {
    local resolved_ip

    if [ -n "${OLLAMA_URL:-}" ]; then
        printf '%s\n' "$OLLAMA_URL"
        return 0
    fi

    if [ -n "${HOST_OLL:-}" ]; then
        resolved_ip=$(getent ahosts "$HOST_OLL" 2>/dev/null | awk '{ print $1 }' | head -n 1)
        if [ -z "$resolved_ip" ]; then
            resolved_ip=$(getent ahosts "${HOST_OLL%%.*}" 2>/dev/null | awk '{ print $1 }' | head -n 1)
        fi
        if [ -n "$resolved_ip" ]; then
            printf 'http://%s:11434\n' "$resolved_ip"
            return 0
        fi
    fi

    printf '%s\n' "http://host.containers.internal:11434"
}

# Run Aider in the current directory.
# @param $@ Aider passthrough arguments.
# @return 0 on success.
aid_run() {
    local data_dir
    local image
    local model
    local ollama_url
    local work_dir

    image="docker.io/paulgauthier/aider"
    data_dir="${XDG_DATA_HOME:-$HOME/.local/share}/aider"
    work_dir="$(pwd)"
    model="${AIDER_MODEL:-}"
    ollama_url=$(resolve_ollama_url)

    [ -n "$model" ] || {
        aid_fail "AIDER_MODEL is not set"
        echo "Example: AIDER_MODEL=ollama_chat/qwen2.5-coder:7b aid run" >&2
        return 1
    }

    mkdir -p "$data_dir"
    if [ -f "$HOME/.gitconfig" ]; then
        aid_podman run --rm -it \
            --userns keep-id \
            -e OLLAMA_API_BASE="$ollama_url" \
            -e HOME="/data" \
            -v "$work_dir:/app" \
            -v "$data_dir:/data" \
            -v "$HOME/.gitconfig:/data/.gitconfig:ro" \
            -w /app \
            "$image" \
            --model "$model" \
            --no-auto-commits \
            --no-dirty-commits \
            "$@"
        return 0
    fi

    aid_podman run --rm -it \
        --userns keep-id \
        -e OLLAMA_API_BASE="$ollama_url" \
        -e HOME="/data" \
        -v "$work_dir:/app" \
        -v "$data_dir:/data" \
        -w /app \
        "$image" \
        --model "$model" \
        --no-auto-commits \
        --no-dirty-commits \
        "$@"
}

# Pull the Aider image.
# @return 0 on success.
aid_pull() {
    aid_podman pull docker.io/paulgauthier/aider
}

# Print Aider image status.
# @return 0 on success.
aid_status() {
    aid_podman images docker.io/paulgauthier/aider
}

# Remove persistent Aider data.
# @return 0 on success.
aid_remove() {
    rm -rf "${XDG_DATA_HOME:-$HOME/.local/share}/aider"
}

# Remove persistent Aider data and image.
# @return 0 on success.
aid_nuke() {
    aid_remove
    aid_podman rmi docker.io/paulgauthier/aider >/dev/null 2>&1 || true
}

# Run the selected command.
# @param $@ Command arguments.
# @return 0 on success, 1 on invalid command.
aid_main() {
    local command

    command="${1:-}"
    shift 2>/dev/null || true

    case "$command" in
        install)
            aid_pull
            ;;
        run)
            aid_run "$@"
            ;;
        status)
            aid_status
            ;;
        remove)
            aid_remove
            ;;
        nuke)
            aid_nuke
            ;;
        *)
            aid_help >&2
            return 1
            ;;
    esac
}

aid_main "$@"
