#!/bin/bash
# xmouse - Toggle pointer coordinate transformation mode
# Summary: Switches pointer devices between normal and tablet coordinate modes.
# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

set -e

STATUS_FILE="/tmp/xmouse_mode"
M_TABLET="0 -1 1 1 0 0 0 0 1"
M_NORMAL="1 0 0 0 1 0 0 0 1"

# Apply one coordinate transformation matrix to all pointer devices.
# @param $1 Coordinate transformation matrix.
# @return 0 on success.
apply_pointer_matrix() {
    local matrix
    local device_id
    local m1
    local m2
    local m3
    local m4
    local m5
    local m6
    local m7
    local m8
    local m9

    matrix="$1"
    read -r m1 m2 m3 m4 m5 m6 m7 m8 m9 <<< "$matrix"

    for device_id in $(xinput list --id-only); do
        xinput set-prop "$device_id" "Coordinate Transformation Matrix" \
            "$m1" "$m2" "$m3" "$m4" "$m5" "$m6" "$m7" "$m8" "$m9" \
            2>/dev/null || true
    done
}

# Return the current pointer mode.
# @return Current mode on stdout.
get_pointer_mode() {
    [ -f "$STATUS_FILE" ] || {
        printf '%s\n' "normal"
        return 0
    }

    cat "$STATUS_FILE"
}

# Switch pointer devices to tablet mode.
# @return 0 on success.
enable_tablet_mode() {
    apply_pointer_matrix "$M_TABLET"
    printf '%s\n' "tablet" > "$STATUS_FILE"
    printf '%s\n' "INVERTED MODE"
}

# Switch pointer devices to normal mode.
# @return 0 on success.
enable_normal_mode() {
    apply_pointer_matrix "$M_NORMAL"
    printf '%s\n' "normal" > "$STATUS_FILE"
    printf '%s\n' "NORMAL MODE"
}

# Toggle pointer mode.
# @return 0 on success.
main() {
    case "$(get_pointer_mode)" in
        normal)
            enable_tablet_mode
            ;;
        *)
            enable_normal_mode
            ;;
    esac
}

main "$@"
