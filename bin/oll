#!/bin/bash
# oll - Ollama runner for Podman with GPU support
# Summary: Starts and manages Ollama in a Podman container.
# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

set -e

IMAGE="docker.io/ollama/ollama:latest"
NAME="ollama"
PORT="11434"
VOL_NAME="ollama_data"

# Print command usage.
# @return 0 on success.
oll_help() {
    echo "Usage: oll <command> [args...]"
    echo
    echo "Commands:"
    echo "  install  Install (pull) Ollama image"
    echo "  start    Start Ollama container with GPU support"
    echo "  stop     Stop Ollama container, or stop a model when args are given"
    echo "  logs     Follow container logs"
    echo "  status   Show container status"
    echo "  remove   Remove container and persistent models"
    echo "  nuke     Remove container, models, and local image"
    echo "  shell    Open a shell inside the Ollama container"
    echo "  exec     Run a raw command inside the Ollama container"
    echo "  ollama   Run any Ollama CLI command inside the container"
    echo
    echo "Ollama commands:"
    echo "  list     List installed models"
    echo "  ps       List running models"
    echo "  pull     Pull a model"
    echo "  run      Run a model"
    echo "  launch   Launch an Ollama app or artifact"
    echo "  serve    Start Ollama server in the container foreground"
    echo "  show     Show model information"
    echo "  stop     Stop a running model when a model name is given"
    echo "  push     Push a model"
    echo "  rm       Remove a model"
    echo "  cp       Copy a model"
    echo "  create   Create a model from a Modelfile"
    echo "  help     Show Ollama help"
    echo
}

# Pull the Ollama container image.
# @return 0 on success.
oll_install() {
    echo "[INFO] Preparing Ollama installation..."
    sudo podman pull "$IMAGE"
    echo "[OK] Ollama is ready to start."
}

# Start the Ollama container.
# @return 0 on success.
oll_start() {
    echo "[INFO] Starting Ollama..."
    sudo podman rm -f "$NAME" >/dev/null 2>&1 || true

    local gpu_flags=()
    if command -v nvidia-ctk >/dev/null 2>&1 && sudo nvidia-ctk cdi list 2>/dev/null | grep -q "nvidia.com/gpu=all"; then
        gpu_flags=(--device "nvidia.com/gpu=all" --security-opt "label=disable")
        echo "[INFO] GPU support detected and enabled."
    else
        echo "[WARN] GPU support not detected. Running on CPU."
    fi

    sudo podman run -d \
        --name "$NAME" \
        -p "${PORT}:11434" \
        -v "${VOL_NAME}:/root/.ollama" \
        "${gpu_flags[@]}" \
        "$IMAGE"

    echo "[OK] Ollama is running at http://localhost:${PORT}"
}

# Stop and remove the Ollama container.
# @return 0 on success.
oll_stop() {
    sudo podman rm -f "$NAME" >/dev/null 2>&1 || true
}

# Follow Ollama container logs.
# @return 0 on success.
oll_logs() {
    sudo podman logs -f "$NAME"
}

# Show Ollama container status.
# @return 0 on success.
oll_status() {
    sudo podman ps -a --filter "name=${NAME}"
}

# Run a command inside the Ollama container.
# @param $@ Command and arguments.
# @return 0 on success.
oll_exec() {
    sudo podman exec -it "$NAME" "$@"
}

# Run an Ollama CLI command inside the container.
# @param $@ Ollama command arguments.
# @return 0 on success.
oll_ollama() {
    oll_exec ollama "$@"
}

# Open a shell inside the Ollama container.
# @return 0 on success.
oll_shell() {
    oll_exec bash
}

# Remove the Ollama container and persistent volume.
# @return 0 on success.
oll_remove() {
    oll_stop
    sudo podman volume rm "$VOL_NAME" >/dev/null 2>&1 || true
}

# Remove the Ollama container, persistent volume, and image.
# @return 0 on success.
oll_nuke() {
    oll_remove
    sudo podman rmi "$IMAGE" >/dev/null 2>&1 || true
}

# Run the Ollama command dispatcher.
# @param $@ Command arguments.
# @return 0 on success.
oll_main() {
    case "${1:-}" in
        install) oll_install ;;
        start) oll_start ;;
        stop)
            shift
            if [ "$#" -gt 0 ]; then
                oll_ollama stop "$@"
            else
                oll_stop
            fi
            ;;
        logs) oll_logs ;;
        status) oll_status ;;
        remove) oll_remove ;;
        nuke) oll_nuke ;;
        shell) oll_shell ;;
        exec) shift; oll_exec "$@" ;;
        ollama) shift; oll_ollama "$@" ;;
        list|ps|pull|run|launch|serve|show|push|rm|cp|create|help)
            oll_ollama "$@"
            ;;
        *) oll_help >&2; return 1 ;;
    esac
}

oll_main "$@"
